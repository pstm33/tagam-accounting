DATABASE_URL=postgres://tagam:tagam@localhost:5432/tagam_accounting
API_HOST=0.0.0.0
API_PORT=4010
ACCOUNTING_AUTH_MODE=off
# Comma-separated key_id:secret pairs. Set ACCOUNTING_AUTH_MODE=protected or strict when enabling.
ACCOUNTING_API_KEYS=
ACCOUNTING_HMAC_SECRETS=
ACCOUNTING_HMAC_TOLERANCE_SECONDS=300
ACCOUNTING_WEB_USERNAME=admin
ACCOUNTING_WEB_PASSWORD=CHANGE_ME
ACCOUNTING_WEB_SESSION_SECRET=CHANGE_ME_RANDOM_32_BYTES
ACCOUNTING_WEB_PRINCIPAL=kmrs_bridge
ACCOUNTING_WEB_SESSION_MAX_AGE_SECONDS=43200
ACCOUNTING_WEB_COOKIE_SECURE=false
# JSON object keyed by API key id / HMAC key id.
# Example:
# ACCOUNTING_BRIDGE_SCOPES={"kmrs_bridge":{"organizationIds":["org-id"],"locationIds":["location-id"],"restaurantSlugs":["7sky"],"kmrsMerchantIds":["7"],"baseUrls":["https://tagam.delivery"]}}
ACCOUNTING_BRIDGE_SCOPES=
